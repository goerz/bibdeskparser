@article{GoerzJPB2011,
	abstract = {We study controlled phasegates for ultracold atoms in an optical potential. A shaped laser pulse drives transitions between the ground and electronically excited states where the atoms are subject to a long-range 1/ R 3 interaction. We fully account for this interaction and use optimal control theory to calculate the pulse shapes. This allows us to determine the minimum pulse duration, respectively, gate time T that is required to obtain high fidelity. We accurately analyse the speed limiting factors, and we find the gate time to be limited either by the interaction strength in the excited state or by the ground state vibrational motion in the trap. The latter needs to be resolved by the pulses in order to fully restore the motional state of the atoms at the end of the gate.},
	archiveprefix = {arXiv},
	author = {Goerz, Michael H and Calarco, Tommaso and Koch, Christiane P},
	date-added = {2026-07-04 09:04:26 -0400},
	date-modified = {2026-07-04 12:57:33 -0400},
	doi = {10.1088/0953-4075/44/15/154011},
	eprint = {1103.6050},
	journal = jpb,
	keywords = {Rydberg atoms, quantum computing, quantum information},
	number = {15},
	pages = {154011},
	title = {The quantum speed limit of optimal controlled phasegates for trapped neutral atoms},
	volume = {44},
	year = {2011},
	bdsk-file-1 = {},
	bdsk-url-1 = {http://stacks.iop.org/0953-4075/44/i=15/a=154011}}

@article{GoerzNJP2014,
	abstract = {We show that optimizing a quantum gate for an open quantum system requires the time evolution of only three states irrespective of the dimension of Hilbert space. This represents a significant reduction in computational resources compared to the complete basis of Liouville space that is commonly believed necessary for this task. The reduction is based on two observations: the target is not a general dynamical map but a unitary operation; and the time evolution of two properly chosen states is sufficient to distinguish any two unitaries. We illustrate gate optimization employing a reduced set of states for a controlled phasegate with trapped atoms as qubit carriers and a {$\sqrt{i{\rm{S}}WAP}$} gate with superconducting qubits.},
	archiveprefix = {arXiv},
	author = {Goerz, Michael H and Reich, Daniel M and Koch, Christiane P},
	date-added = {2026-07-04 09:04:26 -0400},
	date-modified = {2026-07-04 09:04:26 -0400},
	doi = {10.1088/1367-2630/16/5/055012},
	eprint = {1312.0111},
	journal = njp,
	number = {5},
	pages = {055012},
	title = {Optimal control theory for a unitary operation under dissipative evolution},
	volume = {16},
	year = {2014},
	bdsk-file-1 = {},
	bdsk-url-1 = {http://stacks.iop.org/1367-2630/16/i=5/a=055012}}

