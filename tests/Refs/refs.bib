	journal = epjd,
	keywords = {Coherent Control, Ultracold Atoms},
	number = {2},
	pages = {239},
	primaryclass = {physics.atm-clus},
	title = {Optimizing the photoassociation of cold atoms by use of chirped laser pulses},
	volume = {31},
	year = {2004}}

@unpublished{Wilhelm2003.10132,
	abstract = {In this series of lectures, we would like to introduce the audience to quantum optimal control. The first lecture will cover basic ideas and principles of optimal control with the goal of demystifying its jargon. The second lecture will describe computational tools (for computations both on paper and in a computer) for its implementation as well as their conceptual background. The third chapter will go through a series of popular examples from different applications of quantum technology.},
	archiveprefix = {arXiv},
	author = {Wilhelm, Frank K. and Kirchhoff, Susanna and Machnes, Shai and Wittler, Nicolas and Sugny, Dominique},
